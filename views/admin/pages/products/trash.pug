extends ../../layouts/default.pug
include ../../mixins/pagination.pug

block main
    h1 Sản phẩm đã xóa

    a.btn.btn-primary.mb-3(href=`${prefixAdmin}/products`)
        | Quay lại danh sách

    .card.mb-3
        .card-header Danh sách sản phẩm đã xóa
        .card-body
            table.table.table-hover.table-sm
                thead
                    tr
                        th STT
                        th Hình ảnh
                        th Tiêu đề
                        th Giá
                        th Hành động
                tbody
                    each item, index in products
                        tr
                            td #{index + 1}
                            td
                                img(
                                    src=item.thumbnail
                                    alt=item.title
                                    width="100"
                                )
                            td #{item.title}
                            td #{item.price}$
                            td
                                form(
                                    action=`${prefixAdmin}/products/restore/${item._id}?_method=PATCH`
                                    method="POST"
                                )
                                    button.btn.btn-success.btn-sm Khôi phục

    +pagination(pagination)