extends ../../layouts/default.pug

block main
    h1 Danh sách sản phẩm

    .card.mb-3
        .card-header Bộ lọc và tìm kiếm
        .card-body
            .row
                .col-6
                    each item in filterStatus
                        button(
                            type="button"
                            class=`btn btn-sm ms-1 btn-outline-success ${item.class}`
                            button-status=item.status
                        ) #{item.name}

                .col-6
                    form#form-search
                        .input-group
                            input.form-control(
                                type="text"
                                placeholder="Nhập từ khóa"
                                name="keyword"
                                value=(query.keyword || "")
                            )
                            .input-group-append
                                button.btn.btn-success(type="submit") Tìm

    .card.mb-3
        .card-header Danh sách sản phẩm
        .card-body
            table.table.table-bordered
                thead
                    tr
                        th STT
                        th Hình ảnh
                        th Tiêu đề
                        th Giá
                        th Trạng thái
                        th Hành động
                tbody
                    each item, index in products
                        tr
                            td #{index + 1}
                            td
                                img(
                                    src=item.thumbnail
                                    alt=item.title
                                    width="100"
                                )
                            td #{item.title}
                            td #{item.price}$
                            td
                                if item.status == "active"
                                    span.badge.bg-success Hoạt động
                                else
                                    span.badge.bg-secondary Dừng hoạt động
                            td
                                button.btn.btn-warning.btn-sm Sửa
                                button.btn.btn-danger.btn-sm.ms-1 Xóa
