extends ../../layouts/default.pug

block main 
    if(product.title)
        h1(class="mb-4") #{product.title}

    .product-detail-page 
        .card.mb-4 
            .card-header 
                strong Thông tin chi tiết
            .card-body
                .row
                    .col-md-4
                        if(product.thumbnail)
                            div(class="mb-4")
                                img(
                                    src=product.thumbnail
                                    class="image-detail"
                                )
                    .col-md-8
                        if(product.price)
                            div(class="mb-4") Giá: <b>#{product.price}$</b>
                        
                        if(product.discountPercentage)
                            div(class="mb-4") Giảm giá: <b>#{product.discountPercentage}%</b>
                        
                        if(product.stock)
                            div(class="mb-4") Tồn kho: <b>#{product.stock}</b>
                        
                        if(product.status)
                            div(class="mb-4")
                                span Trạng thái: 
                                if(product.status == "active")
                                    span.badge.bg-success Hoạt động
                                else
                                    span.badge.bg-secondary Dừng hoạt động

                        if(product.position)
                            div(class="mb-4")
                                span Vị trí: <b>#{product.position}</b>
                        
                        if(product.description)
                            div(class="mb-4")
                                span Mô tả:
                                div(class="inner-desc") !{product.description}

    a(
        href=`${prefixAdmin}/products/edit/${product.id}`
        class="btn btn-warning") Chỉnh sửa
        
    script(src="/admin/js/product.js") 