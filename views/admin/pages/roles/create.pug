extends ../../layouts/default.pug

block main
    if(role.permissions.includes("roles_create"))
        h1(class="mb-4") Tạo mới nhóm quyền

        form(
            action='/admin/roles/create', 
            method='POST'
        )
            div(class='form-group')
                label(for='title') Tên nhóm quyền
                input(
                    type='text', 
                    class='form-control', 
                    id='title', 
                    name='title', 
                    required
                )
            div(class='form-group')
                label(for='description') Mô tả ngắn
                input(
                    type='text', 
                    class='form-control', 
                    id='desc', 
                    name='description',
                )
            div(class="form-group")
                button(
                    type="submit", 
                    class="btn btn-primary"
                ) Tạo nhóm quyền

    