extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    .container.my-3 
        include ../../partials/list-btn-users.pug

        .row 
            .col-12 
                +box-head("Lời mời kết bạn")

        
        .row(data-users-accept=user.id)
            each user in users
                .col-6 
                    div(class="box-user box-user-friend")
                        div(class="inner-avatar")
                            img(
                                    src=(user.avatar ? user.avatar : "https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_1280.png")
                                    alt=user.fullname
                                    class="rounded-circle"
                                    width="80"
                                    height="80"
                            )

                        div(class="inner-info")
                            div(class="inner-name") #{user.fullname}
                            div(class="inner-buttons")
                                button(
                                    class="btn btn-sm btn-primary m-1"
                                    btn-accept-friend = user.id
                                ) Chấp nhận 
                                button(
                                    class="btn btn-sm btn-secondary m-1"
                                    btn-refuse-friend = user.id
                                ) Xóa
                                button(
                                    class="btn btn-sm btn-secondary m-1"
                                    btn-delete-friend = user.id
                                    disabled
                                ) Đã xóa
                                button(
                                    class="btn btn-sm btn-primary m-1"
                                    btn-accepted-friend = user.id
                                    disabled
                                ) Đã chấp nhận
