extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  // ===== Product List =====
  .container.my-3
    .row
      .col-12
        +box-head("Danh sách sản phẩm")

    .row
      each item in products
        .col-4.mb-3
          .product-item
            .inner-image
              img(
                src=item.thumbnail
                alt=item.title
              )
            .inner-content
              h3.inner-title
                a(href=`/products/${item.slug}`) #{item.title}
              .inner-price-new.text-success.fw-bold= item.priceNew + "$"
              .inner-price-old.text-secondary.text-decoration-line-through= item.price + "$"
              .inner-discount.badge.bg-danger.text-white= "-" + item.discountPercentage + "%"