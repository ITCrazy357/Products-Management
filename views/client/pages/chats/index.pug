extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main 
    .container.my-3 
        .row 
            .col-12 
                +box-head("Chat")
            
            .chat(my-id=userInfo.id)
                .image-preview-container
                
                .inner-body
                    each chat in chats
                        div(class=(chat.user_id == userInfo.id ? "inner-outgoing" : "inner-incoming"))
                            if(chat.user_id != userInfo.id)
                                .inner-name #{chat.infoUser.fullname}
                            if(chat.content)
                                .inner-content
                                    | #{chat.content}
                            if(chat.images && chat.images.length > 0)
                                .inner-images 
                                    each image in chat.images
                                        img(src=image)

                    div(class="inner-list-typing")

                .inner-foot
                    form(
                        class="inner-form"
                        action=""
                    )
                        input(
                            type="text"
                            placeholder="Nhập nội dung..."
                            name="content"
                        )
                        input.filepond(
                            type="file"
                            name="images"
                            multiple
                            )
                        span(class="button-icon button-icon-smile")
                            i.fa-regular.fa-face-smile
                        button(type="submit")
                            i.fa-solid.fa-paper-plane


        div(class="tooltip" role="tooltip")
            emoji-picker
                